generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Movie {
  id             String            @id @default(uuid())
  sourceUrl      String            @unique
  title          String
  thumbnail      String?
  description    String?           @db.Text
  genre          String?
  year           String?
  duration       String?
  rating         String?
  quality        String?
  releaseDate    String?
  actors         String[]          @default([])
  directors      String[]          @default([])
  streams        String?           @db.Text
  detailSyncedAt DateTime?
  inHome         Boolean           @default(false)
  inPopular      Boolean           @default(false)
  inNew          Boolean           @default(false)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  streamCache    MovieStreamCache?
  favorites      UserFavorite[]
  watchHistories WatchHistory[]

  @@index([updatedAt])
  @@index([inHome, updatedAt])
  @@index([inPopular, updatedAt])
  @@index([inNew, updatedAt])
  @@index([detailSyncedAt])
}

model MovieStreamCache {
  id           String   @id @default(uuid())
  movieId      String   @unique
  sourceUrl    String   @unique
  resolvedFrom String?  @db.Text
  originalUrl  String?  @db.Text
  iframe       String?  @db.Text
  m3u8         String?  @db.Text
  sources      Json     @db.JsonB
  checkedAt    DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  movie        Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@index([checkedAt])
}

model User {
  id                String             @id @default(uuid())
  name              String
  email             String             @unique
  passwordHash      String
  passwordSalt      String
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  sessions          UserSession[]
  favorites         UserFavorite[]
  watchHistory      WatchHistory[]
  affiliateProfile  AffiliateProfile?
  affiliateReferral AffiliateReferral?
}

model UserSession {
  id         String   @id @default(uuid())
  tokenHash  String   @unique
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model UserFavorite {
  id        String   @id @default(uuid())
  userId    String
  movieId   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie     Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@unique([userId, movieId])
  @@index([userId, createdAt])
  @@index([movieId])
}

model WatchHistory {
  id              String   @id @default(uuid())
  userId          String
  movieId         String
  progressSeconds Int      @default(0)
  durationSeconds Int?
  completed       Boolean  @default(false)
  lastWatchedAt   DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie           Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@unique([userId, movieId])
  @@index([userId, lastWatchedAt])
  @@index([movieId])
}

model AffiliateProfile {
  id               String                   @id @default(uuid())
  userId           String                   @unique
  referralCode     String                   @unique
  totalClicks      Int                      @default(0)
  totalSignups     Int                      @default(0)
  activeReferrals  Int                      @default(0)
  totalCommission  Int                      @default(0)
  availableBalance Int                      @default(0)
  pendingBalance   Int                      @default(0)
  withdrawnBalance Int                      @default(0)
  minimumWithdraw  Int                      @default(50000)
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  user             User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  referrals        AffiliateReferral[]
  payoutRequests   AffiliatePayoutRequest[]
  activities       AffiliateActivity[]

  @@index([createdAt])
}

model AffiliateReferral {
  id               String           @id @default(uuid())
  profileId        String
  referredUserId   String           @unique
  status           String           @default("registered")
  commissionEarned Int              @default(0)
  activatedAt      DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  profile          AffiliateProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  referredUser     User             @relation(fields: [referredUserId], references: [id], onDelete: Cascade)

  @@index([profileId, createdAt])
  @@index([status])
}

model AffiliatePayoutRequest {
  id        String           @id @default(uuid())
  profileId  String
  amount     Int
  status     String          @default("pending")
  note       String?         @db.Text
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  profile    AffiliateProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, createdAt])
  @@index([status])
}

model AffiliateActivity {
  id          String           @id @default(uuid())
  profileId    String
  type         String
  title        String
  description  String?         @db.Text
  amount       Int?
  createdAt    DateTime        @default(now())
  profile      AffiliateProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, createdAt])
  @@index([type])
}
